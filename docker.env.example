# Copy this file to .env and edit before running docker compose.
# All values have safe defaults — only change what you need.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=crown
POSTGRES_PASSWORD=crownpass          # change this on any network-accessible server
POSTGRES_DB=crown_tracker

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=3000                        # host port the app will be reachable on

# DATABASE_URL is constructed automatically from the three POSTGRES_* vars above.
# Only set this manually if you point the app at an external Postgres instance.
# DATABASE_URL=postgres://crown:crownpass@localhost:5432/crown_tracker
